---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Fusion BOP</title>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen">
    <nav class="flex gap-6 p-4 border-b border-slate-800">
      <a href="/">Overview</a>
      <a href="/thermo-background">Thermodynamics Background</a>
      <a href="/tokamak-systems">Tokamak Systems</a>
      <a href="/rankine">H2O Rankine</a>
      <a href="/co2-brayton">CO2 Brayton</a>
      <a href="/he-brayton">He Brayton</a>
    </nav>
    <main class="p-6">
      <slot />
    </main>
  </body>
</html>